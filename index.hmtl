<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Love Poems Coffee Shop — POS</title>
<link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>
<body class="login-active">

<!-- ============ LOGIN SCREEN ============ -->
<div id="loginScreen">
  <div class="login-card">
    <div class="login-emblem">📜☕📜</div>
    <div class="login-title">LOVE POEMS COFFEE SHOP</div>
    <div class="login-sub">"Masuki Kedai, Wahai Petualang Kata"</div>
    <hr class="login-divider">

    <form id="loginForm">
      <div class="field-group">
        <label class="field-label">Nama Pengguna</label>
        <div class="field-input-wrap">
          <span class="icon">🪶</span>
          <input type="text" id="loginUsername" autocomplete="username" placeholder="Chikal Ziaulhaq">
        </div>
      </div>
      <div class="field-group">
        <label class="field-label">Kata Sandi</label>
        <div class="field-input-wrap">
          <span class="icon">🔑</span>
          <input type="password" id="loginPassword" autocomplete="current-password" placeholder="Masukkan kata sandi">
        </div>
      </div>
      <button type="submit" class="login-btn">MASUK KE KEDAI ✒️</button>
      <div class="login-error" id="loginError"></div>
    </form>
    <div class="login-footer">LOVE POEMS © — Coffee &amp; High Poetry</div>
  </div>
</div>

<!-- ============ LOADING GATE (transisi) ============ -->
<div id="loadingGate">
  <div class="gate-emblem">🕯️📜🕯️</div>
  <div class="gate-text">MEMBUKA GERBANG KEDAI...</div>
  <div class="gate-bar"><div class="gate-bar-fill"></div></div>
</div>

<!-- ============ MAIN POS APP ============ -->
<div id="posApp">

<h1>📜 LOVE POEMS COFFEE SHOP 📜</h1>
<p class="subtitle">"Merajut Kisah dan Puisi dalam Setiap Regukan Kehangatan"</p>
<hr>

<div class="layout">
  <div class="panel-left">
    <div class="admin-toggle">
      <button id="riwayatToggleBtn" onclick="toggleRiwayatPanel()">📊 Riwayat &amp; Pendapatan</button>
      <button id="adminToggleBtn" onclick="toggleAdminForm()">🛠️ Kelola Menu (Admin)</button>
    </div>

    <div class="riwayat-panel" id="riwayatPanel">
      <h3 class="section-title" style="margin-top:0;">📊 Rekap Penghasilan &amp; Pendapatan</h3>
      <div class="rekap-grid" id="rekapGrid"></div>

      <h3 class="section-title">📅 Rekap Harian (14 Hari Terakhir)</h3>
      <div id="rekapHarianArea"></div>

      <h3 class="section-title">🏆 Menu Terlaris</h3>
      <div id="menuTerlarisArea"></div>

      <h3 class="section-title">📜 Riwayat Transaksi Terbaru</h3>
      <div id="riwayatListArea"></div>
    </div>

    <div class="admin-form" id="adminForm">
      <h3 class="section-title" style="margin-top:0;">Tambah / Perbarui Menu</h3>
      <input type="hidden" id="editingMenuId" value="">
      <label>Nama Menu</label>
      <input type="text" class="plain" id="formNama" placeholder="cth: Kopi Susu Puisi">
      <label>Harga (Rp)</label>
      <input type="number" class="plain" id="formHarga" placeholder="25000">
      <label>URL Foto</label>
      <input type="text" class="plain" id="formFoto" placeholder="https://...">
      <div class="action-row">
        <button class="btn-secondary" type="button" onclick="resetAdminForm()">Batal</button>
        <button class="btn-primary" type="button" onclick="submitMenuForm()">Simpan Menu</button>
      </div>
      <div id="adminAlert"></div>
    </div>

    <h3 class="section-title">☕ Ramuan Kopi (Menu)</h3>
    <div class="menu-grid" id="menuGrid"></div>
  </div>

  <div class="panel-right">
    <h3 class="section-title">🛒 Gulungan Pesanan</h3>
    <div id="cartArea"></div>
    <hr>
    <div class="metric-box">
      <div class="metric-label">Total Upeti / Biaya</div>
      <div class="metric-value" id="totalValue">Rp 0</div>
    </div>
    <label class="order-field-label">Nama Pemesan</label>
    <input type="text" class="plain" id="namaPemesan" placeholder="cth: Budi Santoso">
    <label class="order-field-label">Nomor / Nama Meja</label>
    <input type="text" class="plain" id="nomorMeja" placeholder="cth: Meja 5">
    <input type="number" id="uangBayar" placeholder="Emas / Uang Tunai (Rp)" min="0" step="1000" value="0">
    <div class="action-row">
      <button class="btn-secondary" onclick="resetTransaksi()">🔮 Kosongkan</button>
      <button class="btn-primary" onclick="prosesBayar()">📜 Cetak Manuskrip Struk</button>
    </div>
    <div id="alertArea"></div>
    <div id="receiptArea"></div>
  </div>
</div>

</div><!-- /#posApp -->

<script src="{{ url_for('static', filename='script.js') }}"></script>
</body>
</html>
